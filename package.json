{
  "name": "openclaw-dashboard",
  "version": "0.1.0",
  "description": "OpenClaw Dashboard - Full-stack web application",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm run dev:frontend\" \"pnpm run dev:backend\"",
    "dev:frontend": "pnpm --filter frontend run dev",
    "dev:backend": "pnpm --filter backend run dev",
    "build": "pnpm run build:frontend && pnpm run build:backend",
    "build:frontend": "pnpm --filter frontend run build",
    "build:backend": "pnpm --filter backend run build",
    "install:all": "pnpm install --filter frontend --filter backend",
    "lint": "pnpm --filter frontend run lint && pnpm --filter backend run lint",
    "format": "pnpm --filter frontend run format && pnpm --filter backend run format",
    "test": "pnpm --filter backend run test"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "keywords": ["openclaw", "dashboard", "react", "express", "typescript"],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
