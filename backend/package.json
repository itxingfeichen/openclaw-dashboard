{
  "name": "openclaw-dashboard-backend",
  "version": "0.1.0",
  "description": "OpenClaw Dashboard Backend API",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.js",
    "build": "tsc",
    "lint": "eslint src --fix",
    "lint:check": "eslint src",
    "format": "prettier --write \"src/**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json,md}\"",
    "test": "DB_PATH=./data/test-openclaw.db node --test",
    "test:coverage": "DB_PATH=./data/test-openclaw.db node --test --experimental-test-coverage",
    "test:watch": "DB_PATH=./data/test-openclaw.db node --test --watch",
    "db:migrate": "node scripts/db-migrate.js migrate",
    "db:rollback": "node scripts/db-migrate.js rollback",
    "db:status": "node scripts/db-migrate.js status",
    "db:reset": "node scripts/db-migrate.js reset",
    "db:seed": "node scripts/seed-database.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.2.5",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "directories": {
    "test": "tests"
  },
  "keywords": [
    "openclaw",
    "dashboard",
    "api"
  ],
  "author": "",
  "license": "ISC"
}
