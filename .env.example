# OpenClaw Dashboard - Environment Configuration
# Copy this file to .env and update the values

# ===========================================
# Backend Configuration
# ===========================================

# Server settings
NODE_ENV=production
PORT=3001

# Database configuration (SQLite)
DATABASE_URL=file:/app/data/dev.db

# CORS configuration
CORS_ORIGIN=http://localhost:80

# API configuration
API_PREFIX=/api

# JWT secret key (CHANGE THIS IN PRODUCTION!)
JWT_SECRET=your-super-secret-jwt-key-change-me

# ===========================================
# Frontend Configuration
# ===========================================

# API URL for frontend to connect to backend
VITE_API_URL=http://localhost:3001/api

# Application title
VITE_APP_TITLE=OpenClaw Dashboard

# ===========================================
# Docker Configuration
# ===========================================

# Container names (optional customization)
BACKEND_CONTAINER_NAME=openclaw-dashboard-backend
FRONTEND_CONTAINER_NAME=openclaw-dashboard-frontend

# Port mappings
BACKEND_PORT=3001
FRONTEND_PORT=80
