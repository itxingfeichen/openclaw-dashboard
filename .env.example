# OpenClaw Dashboard - Environment Configuration
# Copy this file to .env and update the values
# 
# IMPORTANT: Never commit .env file to version control!
# This file contains sensitive credentials.

# ===========================================
# Backend Configuration
# ===========================================

# Server settings
NODE_ENV=production
PORT=3001

# Database configuration (SQLite)
# For production, consider using PostgreSQL or MySQL
DATABASE_URL=file:/app/data/dev.db

# CORS configuration
# In production, set this to your actual domain (e.g., https://yourdomain.com)
# Do NOT use '*' in production!
CORS_ORIGIN=http://localhost:80

# API configuration
API_PREFIX=/api

# JWT secret key (REQUIRED - CHANGE THIS IN PRODUCTION!)
# Generate a strong random key: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-me

# ===========================================
# Frontend Configuration
# ===========================================

# API URL for frontend to connect to backend
# In production, use your backend domain (e.g., https://api.yourdomain.com)
VITE_API_URL=http://localhost:3001/api

# Application title
VITE_APP_TITLE=OpenClaw Dashboard

# ===========================================
# Docker Configuration (Optional)
# ===========================================

# Container names (optional customization)
BACKEND_CONTAINER_NAME=openclaw-dashboard-backend
FRONTEND_CONTAINER_NAME=openclaw-dashboard-frontend

# Port mappings
# Change these if ports 80 or 3001 are already in use
BACKEND_PORT=3001
FRONTEND_PORT=80
